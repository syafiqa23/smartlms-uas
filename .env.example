# ============================================================
# Smart LMS — Environment Variables Template
# Salin file ini ke .env dan sesuaikan nilainya sebelum deploy
# ============================================================

# ------------------------------------------
# Django Core
# ------------------------------------------
DJANGO_SECRET_KEY=change-this-smart-lms-secret-key-before-production-use-50chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ------------------------------------------
# Database — PostgreSQL
# ------------------------------------------
DB_NAME=smart_lms
DB_USER=smart_lms_user
DB_PASSWORD=smart_lms_password
DB_HOST=db
DB_PORT=5432

# Alias juga digunakan oleh postgres docker image
POSTGRES_DB=smart_lms
POSTGRES_USER=smart_lms_user
POSTGRES_PASSWORD=smart_lms_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ------------------------------------------
# Docker Runtime
# ------------------------------------------
RUN_MIGRATIONS=True
RUN_COLLECTSTATIC=True
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# ------------------------------------------
# Media & Static
# ------------------------------------------
MEDIA_URL=/media/
STATIC_URL=/static/
