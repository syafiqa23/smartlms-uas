{
  "info": {
    "_postman_id": "smartlms-uas-collection-2024",
    "name": "SmartLMS UAS - API Collection",
    "description": "Koleksi lengkap endpoint REST API Smart Learning Management System (LMS).\n\nCara Penggunaan:\n1. Import collection ini ke Postman\n2. Set variabel {{base_url}} ke: http://localhost:8000/api/v1\n3. Jalankan request 'Login' lalu salin nilai 'access' token\n4. Set variabel {{access_token}} dengan nilai token tersebut\n5. Semua request authenticated akan otomatis menggunakan token Bearer\n\nRole: student | teacher | admin",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string",
      "description": "JWT Access Token dari endpoint /auth/login"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string",
      "description": "JWT Refresh Token dari endpoint /auth/login"
    },
    {
      "key": "course_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "content_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "comment_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "description": "Endpoint untuk register, login, refresh token, logout, dan manajemen profil.",
      "item": [
        {
          "name": "Register (Student)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student01\",\n  \"email\": \"student01@example.com\",\n  \"password\": \"SecurePass123\",\n  \"first_name\": \"Budi\",\n  \"last_name\": \"Santoso\",\n  \"role\": \"student\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "description": "Register pengguna baru sebagai student. Role hanya boleh 'student' atau 'teacher'."
          },
          "response": []
        },
        {
          "name": "Register (Teacher)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"teacher01\",\n  \"email\": \"teacher01@example.com\",\n  \"password\": \"TeacherPass123\",\n  \"first_name\": \"Siti\",\n  \"last_name\": \"Rahayu\",\n  \"role\": \"teacher\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "description": "Register pengguna baru sebagai teacher."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access) {",
                  "    pm.collectionVariables.set('access_token', json.access);",
                  "    pm.collectionVariables.set('refresh_token', json.refresh);",
                  "    console.log('Token berhasil disimpan ke collection variables');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student01\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Login dengan username & password. Respons berisi access & refresh JWT token. Script test otomatis menyimpan token ke variabel collection."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access) {",
                  "    pm.collectionVariables.set('access_token', json.access);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Perbarui access token menggunakan refresh token yang masih valid."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            },
            "description": "Logout (stateless — instruksi client untuk membuang token)."
          },
          "response": []
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            },
            "description": "Mendapatkan profil pengguna yang sedang login."
          },
          "response": []
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Budi\",\n  \"last_name\": \"Updated\",\n  \"bio\": \"Backend developer enthusiast\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            },
            "description": "Update profil pengguna yang sedang login (first_name, last_name, bio)."
          },
          "response": []
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"SecurePass123\",\n  \"new_password\": \"NewSecurePass456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/change-password",
              "host": ["{{base_url}}"],
              "path": ["auth", "change-password"]
            },
            "description": "Ganti password pengguna yang sedang login."
          },
          "response": []
        }
      ]
    },
    {
      "name": "📚 Courses",
